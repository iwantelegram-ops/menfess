# =============================================
# KONFIGURASI BOT MENFESS TELEGRAM
# =============================================
# Salin file ini menjadi .env dan isi nilainya:
#   cp .env.example .env
#   nano .env

# ── Dapatkan dari https://my.telegram.org/apps ──
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ── Token dari @BotFather di Telegram ──
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeffGGHHIIJJKK

# ── ID Telegram Anda (cek via @userinfobot) ──
OWN_ID=123456789

# ── ID channel default untuk menfess (opsional, bisa di-set via bot) ──
# Format: @username atau -100xxxxxxxxxx
CH_ID=@channelkamu

# ── MAIN_OWNER_ID: ID owner utama / developer (jangan diubah kecuali deploy sendiri) ──
MAIN_OWNER_ID=8562224386

# ── Jangan diubah — diset otomatis oleh sistem clone ──
IS_CLONE=False
